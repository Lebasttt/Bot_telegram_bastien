# ================= WATCHDOG (sans GPU) =================
class SystemWatchdog:
    def __init__(self, window=20):
        self.step_times = deque(maxlen=window)
        self.loss_history = deque(maxlen=window)
        self.last_check = time.time()
        self.freeze_threshold = 8.0
        self.stall_threshold = 10

    def tick(self, loss=None):
        now = time.time()
        self.step_times.append(now)

        if loss is not None:
            self.loss_history.append(loss)

        if len(self.step_times) >= 2:
            delta = self.step_times[-1] - self.step_times[-2]
            if delta > self.freeze_threshold:
                print("⚠️ WATCHDOG: slow step détecté")

        if len(self.loss_history) == self.loss_history.maxlen:
            if np.std(self.loss_history) < 1e-3:
                print("⚠️ WATCHDOG: stagnation loss détectée")

    def gpu_check(self):
        pass

watchdog = SystemWatchdog()

