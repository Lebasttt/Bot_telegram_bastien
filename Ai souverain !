    cpu_cleanup()

all_texts_for_tokenizer = []
for texts in domain_map_temp.values():
    all_texts_for_tokenizer.extend(texts)

bpe_tokenizer = BPETokenizer(vocab_size_target=10000)
vocab_size_reel = bpe_tokenizer.train(all_texts_for_tokenizer, max_len=max_len)
print(f"🎯 Vocabulaire BPE réel: {vocab_size_reel} tokens")

vocab_size_modele = vocab_size_reel
print(f"🎯 Vocabulaire du modèle fixé à: {vocab_size_modele} tokens")

radical_ram_cleanup("tokenizer entraîné", 0)

del domain_map_temp, deduplicator_temp
gc.collect()

# ================= BOUCLE PRINCIPALE INFINIE =================
while True:
    cycle_counter += 1
    random.seed(cycle_counter * 1337)
    np.random.seed(cycle_counter * 1337)

    print(f"\n{'🔥'*30}")
    print(f"CYCLE {cycle_counter}")
    print(f"{'🔥'*30}\n")

    # ================= PHASE 1 : TÉLÉCHARGEMENT + ENTRAÎNEMENT =================
    print(f"📡 PHASE 1 - Téléchargement et entraînement")
    print(f"{'-'*40}")

    model = TransformerSouverain(vocab_size_modele, d_model, nhead, num_layers, max_len).to(DEVICE)
    optimizer = optim.AdamW(model.parameters(), lr=LR, weight_decay=0.01)
    scheduler = optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=1000)
    scaler = None
    deduplicator = MinHashDeduplicator()
    clear_temp_dir()

    start_cycle, start_epoch = charger_modele(model, optimizer, scheduler, scaler, LATEST_CHECKPOINT)
    if start_cycle > 0:
        print(f"🔄 Reprise depuis cycle {start_cycle}, epoch {start_epoch}")

    epoch_counter = 0

    for domaine in DOMAIN_WEIGHTS.keys():
        print(f"\n  📂 Domaine: {domaine}")

        batch_buffer = StreamingBatchBuffer(MAX_SAMPLES_PAR_CYCLE)
        all_domain_samples = []

        for name, config, dom, field in DATASETS:
            if dom != domaine:
                continue

            print(f"    → {name}")

            if config:
                ds = load_dataset(name, config, split="train", streaming=True, trust_remote_code=True, token=HF_TOKEN)
            else:
                ds = load_dataset(name, split="train", streaming=True, trust_remote_code=True, token=HF_TOKEN)

            count = 0
            skipped_dup = 0
            skipped_quality = 0
            offset = get_offset(name)
            ds = ds.skip(offset)

            for idx, sample in enumerate(ds):
                if count >= MAX_SAMPLES_PAR_CYCLE:
                    break

                text = sample.get(field) or sample.get("text") or sample.get("content") or sample.get("code") or str(sample)

                if text and len(text) > 50:
                    if len(text) > 20000:
                        continue
                    if deduplicator.is_duplicate(text):
                        skipped_dup += 1
                    elif not is_quality_ok(text, domaine):
                        skipped_quality += 1
                    else:
                        batch_buffer.add(text[:2000])
                        all_domain_samples.append(text[:2000])   # suppression de la limite à 2000
                        count += 1

                        if count % 50 == 0:
                            save_offset(name, offset + count)

                        if batch_buffer.full():
                            samples_batch = batch_buffer.flush()
                            loss = entrainer_sur_samples(model, optimizer, samples_batch, domaine, criterion, scheduler, scaler)
                            print(f"    📉 batch loss: {loss:.4f}")
                            radical_ram_cleanup("batch flush", 0)

                if (idx + 1) % 100 == 0:
                    radical_ram_cleanup(f"streaming {name}", 0)

            new_offset = offset + count
            save_offset(name, new_offset)

            if len(batch_buffer.buffer) > 0:
                samples_batch = batch_buffer.flush()
                loss = entrainer_sur_samples(model, optimizer, samples_batch, domaine, criterion, scheduler, scaler)
                print(f"    📉 final batch loss: {loss:.4f}")

            print(f"      ✅ {len(all_domain_samples)} samples | dup:{skipped_dup} lowq:{skipped_quality}")

            del ds
            gc.collect()
            cpu_cleanup()

        if all_domain_samples:
            save_samples(domaine, all_domain_samples)
            radical_ram_cleanup(f"téléchargement {domaine}", PAUSE_ENTRE_DOMAINES)

    print(f"\n✅ CYCLE {cycle_counter} - PHASE 1 terminée")

    # ================= PHASE 2 : RELECTURE + ENTRAÎNEMENT =================
    print(f"\n📖 PHASE 2 - Relecture des samples (2ème époque)")
    print(f"{'-'*40}")

    for domaine in DOMAIN_WEIGHTS.keys():
        samples = load_samples(domaine)
        if samples:
            print(f"  📂 Domaine: {domaine} - {len(samples)} samples relus")
            random.shuffle(samples)

            radical_ram_cleanup(f"relecture {domaine}", PAUSE_ENTRE_LECTURE_CYCLE2)

            loss = entrainer_sur_samples(model, optimizer, samples, domaine, criterion, scheduler, scaler)
            print(f"    📉 Loss: {loss:.4f}")

    print(f"\n✅ CYCLE {cycle_counter} - PHASE 2 terminée")
    epoch_counter += 1

    # ================= PHASE 3 : SUPPRESSION + EXTINCTION =================
    print(f"\n🗑️ PHASE 3 - Nettoyage et extinction")
    print(f"{'-'*40}")

    clear_temp_dir()
    sauvegarder_modele(model, optimizer, scheduler, scaler, cycle_counter, epoch_counter, "")

    del model
    del optimizer
    del scheduler
    del scaler
    gc.collect()
    cpu_cleanup()

    radical_ram_cleanup("avant pause extinction", PAUSE_APRES_EXTINCTION)

    # ================= PHASE 4 : REQUÊTE (tous les N cycles) =================
    if cycle_counter % REQUETE_TOUS_LES_CYCLES == 0:
        print(f"\n💬 PHASE 4 - REQUÊTE (cycle {cycle_counter})")
        print(f"{'-'*40}")

        model = TransformerSouverain(vocab_size_modele, d_model, nhead, num_layers, max_len).to(DEVICE)
        optimizer = optim.AdamW(model.parameters(), lr=LR, weight_decay=0.01)
        scheduler = optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=1000)
        scaler = None
        dernier_cycle, derniere_epoch = charger_modele(model, optimizer, scheduler, scaler, LATEST_CHECKPOINT)

        for nom, config, dom, field in DATASETS_REQUETES:
            if config:
                ds = load_dataset(nom, config, split="train", streaming=True, trust_remote_code=True, token=HF_TOKEN)
            else:
                ds = load_dataset(nom, split="train", streaming=True, trust_remote_code=True, token=HF_TOKEN)

            for i, sample in enumerate(ds):
                if i >= 5:
                    break

                question = sample.get(field) or sample.get("text") or str(sample)
                if question and len(question) > 10:
                    question = question[:200]
                    print(f"\n  ❓ Question: {question[:80]}...")
                    with torch.inference_mode():
                        reponse = requete_modele(model, question)
                    print(f"  💬 Réponse: {reponse[:150]}...")

                    radical_ram_cleanup(f"requête {i+1}", 0)

            del ds
            gc.collect()

        sauvegarder_modele(model, optimizer, scheduler, scaler, cycle_counter, 0, "_apres_requete")

        del model
        del optimizer
        del scheduler
        del scaler
        gc.collect()
        radical_ram_cleanup("après requête", PAUSE_APRES_REQUETE)

    cuda_manager()
    print(f"\n✅ CYCLE {cycle_counter} COMPLET")
    print(f"⏸️ Pause avant cycle suivant...\n")
    time.sleep(5)

