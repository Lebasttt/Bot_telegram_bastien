# ================= STREAMING BATCH BUFFER =================
class StreamingBatchBuffer:
    def __init__(self, max_size=200):
        self.buffer = deque(maxlen=max_size)

    def add(self, x):
        self.buffer.append(x)

    def full(self):
        return len(self.buffer) >= self.buffer.maxlen

    def flush(self):
        data = list(self.buffer)
        self.buffer.clear()
        return data

