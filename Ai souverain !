# ================= ENTRAÎNEMENT (version CPU) =================
gpu_reset_steps = 0
step_history = deque(maxlen=50)

def entrainer_sur_samples(model, optimizer, samples, domaine, criterion, scheduler=None, scaler=None):
    if not samples:
        return 0.0

    global global_step_counter
    global gpu_reset_steps

    model.train()
    total_loss = 0
    nb_batches = 0
    optimizer.zero_grad(set_to_none=True)

    accum_counter = 0

    for i in range(0, len(samples), batch_size):
        batch_texts = samples[i:i + batch_size]
        batch_tokens = bpe_tokenizer.batch_encode(batch_texts, max_len).to(DEVICE)

        x = batch_tokens[:, :-1]
        y = batch_tokens[:, 1:]

        output = model(x)
        loss = criterion(output.reshape(-1, vocab_size_modele), y.reshape(-1))
        loss_raw = loss.detach().float().item()

        if torch.isnan(loss) or torch.isinf(loss):
            print("⚠️ Loss NaN/Inf détectée")
            optimizer.zero_grad(set_to_none=True)
            continue

        if not hasattr(model, "loss_ema"):
            model.loss_ema = loss_raw
        else:
            model.loss_ema = 0.9 * model.loss_ema + 0.1 * loss_raw
        watchdog.tick(model.loss_ema)

        step_history.append(loss_raw)
        if len(step_history) == step_history.maxlen:
            if np.std(step_history) < 1e-4:
                print("⚠️ STEP VALIDATOR: stagnation critique détectée")
                optimizer.zero_grad(set_to_none=True)
                cpu_cleanup()

        loss.backward()

        accum_counter += 1
        if accum_counter % ACCUM_STEPS == 0:
            torch.nn.utils.clip_grad_norm_(model.parameters(), CLIP_NORM)
            optimizer.step()
            optimizer.zero_grad(set_to_none=True)

            global_step_counter += 1
            if scheduler and global_step_counter % SCHEDULER_STEP_EVERY == 0:
                scheduler.step()

            gpu_reset_steps += 1
            if gpu_reset_steps % 2000 == 0:
                print("🔁 HARD RESET (cleanup)")
                cpu_cleanup()
                time.sleep(3)

            watchdog.gpu_check()
            cuda_manager()

        total_loss += loss_raw
        nb_batches += 1

        del batch_tokens, x, y, output, loss, loss_raw
        cpu_cleanup()

    if accum_counter % ACCUM_STEPS != 0:
        torch.nn.utils.clip_grad_norm_(model.parameters(), CLIP_NORM)
        optimizer.step()
        optimizer.zero_grad(set_to_none=True)
        global_step_counter += 1
        if scheduler and global_step_counter % SCHEDULER_STEP_EVERY == 0:
            scheduler.step()
        gpu_reset_steps += 1
        if gpu_reset_steps % 2000 == 0:
            print("🔁 HARD RESET (cleanup)")
            cpu_cleanup()
            time.sleep(3)

    return total_loss / max(nb_batches, 1)

# ================= REQUÊTE (CPU) =================
def requete_modele(model, question, max_new=100, temperature=0.7):
    model.eval()
    input_ids = torch.tensor(bpe_tokenizer.encode(question)).unsqueeze(0).to(DEVICE)
    generated_ids = input_ids[0].tolist()

    token_history = Counter()
    repeat_penalty = 1.2

    for _ in range(max_new):
        with torch.inference_mode():
            logits = model(input_ids[:, -max_len:])[0, -1]
            logits = logits / temperature
            probs = torch.softmax(logits, dim=-1)
            for t in token_history:
                probs[t] /= repeat_penalty
            next_id = torch.multinomial(probs, 1).item()

        token_history[next_id] += 1

        if next_id >= model.fc_out.out_features or next_id < 0:
            break
        if next_id == bpe_tokenizer.pad_id or token_history[next_id] > 5:
            break

        generated_ids.append(next_id)
        new_input_ids = torch.tensor([generated_ids[-max_len:]]).to(DEVICE)
        input_ids = new_input_ids

    model.train()
    return bpe_tokenizer.decode(generated_ids)

