# ================= MODÈLE TRANSFORMER (CPU) =================
class TransformerSouverain(nn.Module):
    def __init__(self, vocab_size, d_model=256, nhead=8, num_layers=4, max_len=512):
        super().__init__()
        self.embedding = nn.Embedding(vocab_size, d_model, padding_idx=0)
        self.pos_encoding = nn.Parameter(torch.randn(1, max_len, d_model) * 0.02)
        encoder_layer = nn.TransformerEncoderLayer(d_model=d_model, nhead=nhead, batch_first=True, dropout=0.1)
        self.transformer = nn.TransformerEncoder(encoder_layer, num_layers=num_layers)
        self.fc_out = nn.Linear(d_model, vocab_size)
        self.max_len = max_len
        self.d_model = d_model
        self.use_gradient_checkpointing = True
        self.loss_ema = None

    def forward(self, x):
        seq_len = min(x.size(1), self.max_len)
        x = x[:, :seq_len]
        embed = self.embedding(x) * (self.d_model ** 0.5)
        embed = embed + self.pos_encoding[:, :seq_len, :]
        causal_mask = torch.triu(
            torch.full((seq_len, seq_len), float("-inf"), device=x.device),
            diagonal=1
        )
        padding_mask = (x == 0).bool()

        if self.use_gradient_checkpointing and self.training:
            out = checkpoint(
                lambda e: self.transformer(
                    e,
                    src_mask=causal_mask,
                    src_key_padding_mask=padding_mask
                ),
                embed,
                use_reentrant=False
            )
        else:
            out = self.transformer(
                embed,
                src_mask=causal_mask,
                src_key_padding_mask=padding_mask
            )
        return self.fc_out(out)

# ================= TOKENIZER BPE =================
class BPETokenizer:
    def __init__(self, vocab_size_target=10000):
        self.vocab_size_target = vocab_size_target
        self.tokenizer = None
        self.pad_id = None
        self.unk_id = None

    def train(self, texts, max_len=512):
        if len(texts) == 0:
            raise ValueError("Tokenizer training set vide")
        print(f"🔄 Entraînement du tokenizer BPE sur {len(texts)} textes...")
        from tokenizers import Tokenizer
        from tokenizers.models import BPE
        from tokenizers.trainers import BpeTrainer
        from tokenizers.pre_tokenizers import ByteLevel
        self.tokenizer = Tokenizer(BPE(unk_token="[UNK]"))
        self.tokenizer.pre_tokenizer = ByteLevel()

        trainer = BpeTrainer(
            vocab_size=self.vocab_size_target,
            special_tokens=["[PAD]", "[UNK]"],
            min_frequency=2
        )

        self.tokenizer.train_from_iterator(texts, trainer)
        self.pad_id = self.tokenizer.token_to_id("[PAD]")
        self.unk_id = self.tokenizer.token_to_id("[UNK]")
        assert self.pad_id is not None, "[PAD] token introuvable"
        assert self.unk_id is not None, "[UNK] token introuvable"

        self.max_len = max_len

        self.tokenizer.save(TOKENIZER_PATH)
        print(f"💾 Tokenizer sauvegardé: {TOKENIZER_PATH}")

        print(f"✅ Tokenizer entraîné - Vocabulaire réel: {self.tokenizer.get_vocab_size()} tokens")
        return self.tokenizer.get_vocab_size()

    def load(self, path=TOKENIZER_PATH):
        from tokenizers import Tokenizer
        self.tokenizer = Tokenizer.from_file(path)
        self.pad_id = self.tokenizer.token_to_id("[PAD]")
        self.unk_id = self.tokenizer.token_to_id("[UNK]")
        assert self.pad_id is not None, "[PAD] token introuvable"
        assert self.unk_id is not None, "[UNK] token introuvable"
        print(f"🔄 Tokenizer chargé: {path}")

    def encode(self, text, max_len=512):
        encoding = self.tokenizer.encode(text)
        ids = encoding.ids[:max_len]
        if len(ids) < max_len:
            ids += [self.pad_id] * (max_len - len(ids))
        return ids

    def batch_encode(self, texts, max_len=512):
        return torch.tensor([self.encode(t, max_len) for t in texts])

    def decode(self, ids):
        if isinstance(ids, torch.Tensor):
            ids = ids.tolist()
        return self.tokenizer.decode(ids)

# ================= DÉDUPLICATION =================
class MinHashDeduplicator:
    def __init__(self, num_hashes=16):
        self.num_hashes = num_hashes
        self.seen_signatures = set()

    def _hash_text(self, text):
        normalized = " ".join(text.lower().strip().split())
        normalized = normalized[:1000]
        chunk_size = 100
        chunks = [normalized[i:i+chunk_size] for i in range(0, len(normalized), chunk_size)]
        signatures = []
        for chunk in chunks[:8]:
            h = hashlib.blake2b(chunk.encode(), digest_size=16).hexdigest()
            signatures.append(h)
        return tuple(signatures)

    def is_duplicate(self, text):
        sig = self._hash_text(text)
        if sig in self.seen_signatures:
            return True
        self.seen_signatures.add(sig)
        return False

    def reset(self):
        self.seen_signatures.clear()

# ================= SCORING QUALITÉ =================
def clamp(x, min_v=0.0, max_v=0.9):
    return max(min(x, max_v), min_v)

def quality_score(text, domain="languages"):
    score = 0.0

    if len(text) > 50:
        score += 0.3
    if any(p in text for p in ['.', '!', '?', ';', ':']):
        score += 0.2

    digit_ratio = sum(c.isdigit() for c in text) / max(len(text), 1)
    if digit_ratio < 0.3:
        score += 0.2

    if len(text.split()) > 10:
        score += 0.3

    if domain == "code" and any(c in text for c in "={}[]();+-*/<>"):
        score = min(score + 0.2, 1.0)

    noise = 0.92 + 0.08 * random.random()
    score = score * noise

    return clamp(score, 0.0, 0.9)

def is_quality_ok(text, domain):
    thresh = QUALITY_THRESHOLDS.get(domain, QUALITY_GLOBAL_THRESHOLD)
    return quality_score(text, domain) >= thresh

# ================= DOMAIN SAMPLER =================
class DomainSampler:
    def __init__(self, weights, memory=20):
        self.domains = list(weights.keys())
        self.weights = np.array(list(weights.values()), dtype=np.float32)
        self.recent = deque(maxlen=memory)

    def sample(self):
        candidates = [d for d in self.domains if d not in self.recent]
        if not candidates:
            candidates = self.domains
        w = np.array([DOMAIN_WEIGHTS[d] for d in candidates], dtype=np.float32)
        w = w / w.sum()
        choice = random.choices(candidates, weights=w, k=1)[0]
        self.recent.append(choice)
        return choice

